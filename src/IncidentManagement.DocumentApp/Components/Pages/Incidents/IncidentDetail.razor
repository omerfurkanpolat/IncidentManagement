@page "/incidents/{Id}"
@using IncidentManagement.Shared.Models
@using IncidentManagement.Shared.Services
@using Markdig
@inject IncidentReportRepository ReportRepo
@inject JobResultRepository JobRepo
@rendermode InteractiveServer

<PageTitle>Incident Detay</PageTitle>

@if (_report == null)
{
    <p>Yükleniyor...</p>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>@_report.JobName — <span class="text-danger">@_report.ErrorCode</span></h2>
        <a href="incidents" class="btn btn-outline-secondary">← Geri</a>
    </div>

    <div class="card mb-3">
        <div class="card-header"><strong>HATA BİLGİSİ</strong></div>
        <div class="card-body">
            <p><strong>Hata Kodu:</strong> @_report.ErrorCode</p>
            <p><strong>Mesaj:</strong> @_report.ErrorMessage</p>
            <p><strong>Tarih:</strong> @_report.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</p>
            <p>
                <strong>Durum:</strong>
                <select class="form-select d-inline-block" style="width:150px" @onchange="UpdateStatus">
                    @foreach (var s in Enum.GetValues<IncidentStatus>())
                    {
                        <option value="@s" selected="@(_report.Status == s)">@s</option>
                    }
                </select>
            </p>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header"><strong>LLM ANALİZİ</strong></div>
        <div class="card-body">
            @if (string.IsNullOrWhiteSpace(_report.LlmAnalysis))
            {
                <p class="text-muted">Analiz henüz tamamlanmadı.</p>
            }
            else
            {
                <div class="markdown-body">
                    @((MarkupString)Markdown.ToHtml(_report.LlmAnalysis))
                </div>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-header"><strong>KULLANILAN KAYNAKLAR</strong></div>
        <div class="card-body">
            @if (!_report.SourcesUsed.Any())
            {
                <p class="text-muted">Kaynak bilgisi yok.</p>
            }
            else
            {
                @foreach (var s in _report.SourcesUsed)
                {
                    <span class="badge bg-info text-dark me-1">✓ @s</span>
                }
            }
        </div>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;
    private IncidentReport? _report;

    protected override async Task OnInitializedAsync()
    {
        _report = await ReportRepo.GetByIdAsync(Id);
    }

    private async Task UpdateStatus(ChangeEventArgs e)
    {
        if (_report != null && Enum.TryParse<IncidentStatus>(e.Value?.ToString(), out var status))
        {
            _report.Status = status;
            await ReportRepo.UpdateStatusAsync(_report.Id!, status);
        }
    }
}
